{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Api",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/TicketBooking.Api/bin/Debug/net9.0/TicketBooking.Api.dll",
            "cwd": "${workspaceFolder}/src/TicketBooking.Api",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "AWS_REGION": "us-east-1",
                "AWS_ACCESS_KEY_ID": "test",
                "AWS_SECRET_ACCESS_KEY": "test",
                "AWS_SERVICE_URL": "http://localhost:4566"
            }
        },
        {
            "name": "Admin",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/TicketBooking.Admin/bin/Debug/net9.0/TicketBooking.Admin.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/TicketBooking.Admin",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "AWS_REGION": "us-east-1",
                "AWS_ACCESS_KEY_ID": "test",
                "AWS_SECRET_ACCESS_KEY": "test"
            }
        }
    ]
}